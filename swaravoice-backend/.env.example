# ─────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─────────────────────────────────────────────
# MongoDB Atlas
# Get this from: Atlas → Cluster → Connect → Drivers
# Format: mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/SwaraVoice
# ─────────────────────────────────────────────
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/SwaraVoice

# ─────────────────────────────────────────────
# JWT
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ─────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING
JWT_EXPIRES_IN=8h

# ─────────────────────────────────────────────
# Cloudflare R2
# Get from: Cloudflare Dashboard → R2 → Manage R2 API Tokens → Create Token
# Account ID: Cloudflare Dashboard → right sidebar
# ─────────────────────────────────────────────
R2_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
R2_ACCESS_KEY_ID=YOUR_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=YOUR_R2_SECRET_ACCESS_KEY
R2_BUCKET_NAME=SwaraVoice-audio
# Public URL if you've enabled R2 public access (optional — leave blank to use presigned URLs)
R2_PUBLIC_URL=

# ─────────────────────────────────────────────
# Email (Gmail SMTP)
# Use a Gmail account dedicated to SwaraVoice (not your personal one)
# In Gmail: Settings → Security → 2FA on → App Passwords → generate one
# Paste the 16-char app password (no spaces) as GMAIL_APP_PASSWORD
# ─────────────────────────────────────────────
GMAIL_USER=SwaraVoice.noreply@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# ─────────────────────────────────────────────
# Frontend URL (for CORS)
# ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─────────────────────────────────────────────
# SuperAdmin seed (used only on first run to create your account)
# Remove or blank these out after first run
# ─────────────────────────────────────────────
SUPERADMIN_EMAIL=your@email.com
SUPERADMIN_PASSWORD=ChangeThisImmediately123!
SUPERADMIN_NAME=Rajith
